# ─────────────────────────────────────────────────────────────────────────────
# Parsec Zero — Automated Game Studio
# Copy this file to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Daily API budget (USD). Hard cap — system pauses when hit. ────────────────
DAILY_API_BUDGET_USD=10.00
BUDGET_ALERT_50_PCT=true
BUDGET_ALERT_90_PCT=true

# ── Asset generation ──────────────────────────────────────────────────────────
# Stable Diffusion via Automatic1111 (local GPU)
STABLE_DIFFUSION_URL=http://localhost:7860
SD_MODEL_CHECKPOINT=sd-pixel-art-xl
SD_STYLE_PREFIX=pixel art, 32x32, sci-fi space station, dark palette, neon accents

# Music (Suno API)
SUNO_API_KEY=your-suno-api-key-here

# SFX (ElevenLabs)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ── Godot ─────────────────────────────────────────────────────────────────────
# Full path to godot executable
GODOT_EXECUTABLE=C:/path/to/godot/godot.exe
GODOT_PROJECT_PATH=C:/users/scott/parsec_games/parsec_zero

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-token-here
GITHUB_REPO=your-username/parsec-zero
GIT_AUTHOR_NAME=Parsec Zero Studio Bot
GIT_AUTHOR_EMAIL=bot@parsec-zero.local

# ── Marketing / n8n ──────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/parsec-zero
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-here
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
ITCHIO_API_KEY=your-itchio-api-key

# ── ChromaDB (local, no API key needed) ──────────────────────────────────────
CHROMADB_PATH=C:/users/scott/parsec_games/memory/chromadb

# ── Safety guardrails ─────────────────────────────────────────────────────────
MAX_RETRIES_PER_TASK=5
RETRY_COOLDOWN_SECONDS=30
# Set to true to require manual approval after each completed level
HUMAN_CHECKPOINT_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TOKEN_LOG_PATH=C:/users/scott/parsec_games/logs/tokens.jsonl
