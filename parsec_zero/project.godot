; Engine configuration file.
; Parsec Zero — Derelict space station pixel art action game.
; Godot 4.x project. Do not hand-edit unless you know what you're doing.

config_version=5

[application]

config/name="Parsec Zero"
config/description="A pixel art space station survival game. Built by an automated AI studio."
run/main_scene="res://scenes/levels/level_1.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=800
window/size/viewport_height=600
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[physics]

2d/default_gravity=0

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0

